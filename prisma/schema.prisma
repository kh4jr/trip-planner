generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String?
  trips        Trip[]        @relation("TripOwner")
  participants Participant[]
  friendships  Friend[]      @relation("UserFriendships")
  friendOf     Friend[]      @relation("FriendOfUsers")
}

model Trip {
  id           Int           @id @default(autoincrement())
  name         String
  destination  String
  startDate    DateTime
  endDate      DateTime
  ownerId      Int?
  description  String?       @default("")
  location     String?       @default("Brak lokalizacji")
  createdAt    DateTime      @default(now())

  owner        User?         @relation("TripOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  participants Participant[]
  activities   Activity[]
  expenses     Expense[]
  notes        Note[]
  images       TripImage[]
  items        TripItem[]
}

model Participant {
  id     Int    @id @default(autoincrement())
  name   String @default("Uczestnik")
  email  String @default("")
  role   String @default("member")
  
  userId Int?   @unique
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trips  Trip[]
}

model Friend {
  id       Int    @id @default(autoincrement())
  userId   Int
  friendId Int
  status   String @default("PENDING")

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOfUsers", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model Activity {
  id            Int      @id @default(autoincrement())
  name          String
  time          DateTime
  tripId        Int
  createdByName String?  @default("Użytkownik")
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int    @id @default(autoincrement())
  description String
  amount      Float
  paidBy      String
  category    String @default("food")
  tripId      Int
  trip        Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Note {
  id          Int      @id @default(autoincrement())
  content     String
  author      String   @default("organizator")
  isCompleted Boolean  @default(false)
  completedBy String?
  createdAt   DateTime @default(now())
  tripId      Int
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripItem {
  id          Int     @id @default(autoincrement())
  name        String
  category    String  @default("Inne")
  isCompleted Boolean @default(false)
  packedBy    String?
  tripId      Int
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Todo {
  id          Int      @id @default(autoincrement())
  tripId      Int
  content     String
  category    String   @default("Inne")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TripImage {
  id         Int      @id @default(autoincrement())
  url        String
  caption    String?
  uploadedBy String
  createdAt  DateTime @default(now())
  tripId     Int
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
