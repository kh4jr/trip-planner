generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Participant {
  id     Int    @id @default(autoincrement())
  name   String
  email  String @default("")
  role   String @default("member")
  userId Int?    @unique
  trips  Trip[]  @relation("TripParticipants")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String?
  trips    Trip[]
}

model Trip {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  location     String?
  destination  String
  startDate    DateTime
  endDate      DateTime
  userId       Int      @unique
  activities   Activity[]
  expenses     Expense[]
  notes        Note[]
  participants Participant[] @relation("TripParticipants")
  user         User?         @relation(fields: [userId], references: [id])
  images       TripImage[]
  items        TripItem[]
}

model Activity {
  id     Int      @id @default(autoincrement())
  name   String
  time   DateTime
  tripId Int
  trip   Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int    @id @default(autoincrement())
  description String
  amount      Float
  paidBy      String
  category    String @default("other")
  tripId      Int
  trip        Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Note {
  id          Int      @id @default(autoincrement())
  content     String
  author      String
  isCompleted Boolean  @default(false)
  completedBy String?
  createdAt   DateTime @default(now())
  tripId      Int
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripItem {
  id       Int     @id @default(autoincrement())
  name     String
  category String
  isPacked Boolean @default(false)
  packedBy String?
  tripId   Int
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Todo {
  id          Int      @id @default(autoincrement())
  tripId      Int
  content     String
  category    String   @default("Inne")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TripImage {
  id         Int      @id @default(autoincrement())
  url        String
  caption    String?
  uploadedBy String
  createdAt  DateTime @default(now())
  tripId     Int
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
